{
	"schemaVersion": 1,
	"id": "eclipse",
	"version": "${version}",
	"name": "Eclipse",
	"description": "This is a library of all clientside and useful mods i made.",
	"authors": [
		"Jeremia Sell"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/eclipse/eclipse.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.eclipsew.Eclipse"
		],
		"client": [
			"com.eclipsew.EclipseClient"
		]
	},
	"mixins": [
		"eclipse.mixins.json",
		{
			"config": "eclipse.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}